

















import cv2 as cv
import numpy as np
import matplotlib.pyplot as plt 
from IPython.display import clear_output
from scipy.fft import rfft, rfftfreq
from scipy.signal import windows
import time


# Functions written in separate python file for utilities function.
import utilities as ut





# Video file path.
path = './pictures/Video-from-mobile.mov'
# path = './pictures/videoLibrary.mp4'

capture = cv.VideoCapture(path, cv.CAP_FFMPEG)

# Checking whether the file opened successfully or not.
if not capture.isOpened():
    print('Unable to open video file.')
    exit()






# Dimension of frame
width  = int(capture.get(cv.CAP_PROP_FRAME_WIDTH))
height = int(capture.get(cv.CAP_PROP_FRAME_HEIGHT))
no_frames = int(capture.get(cv.CAP_PROP_FRAME_COUNT))

frames = np.zeros((no_frames, height, width, 3), dtype=np.uint8)
frames_count = 0

try:
    while frames_count < no_frames:
        
        # Read frame by frame.
        status, frame = capture.read()
    
        # If 'status' is False, then we have reached the end of video.
        if not status:
            break

        # Converting BGR color format to RGB format for Matplotlib.
        frame_rgb = cv.cvtColor(frame, cv.COLOR_BGR2RGB)
        print(frame_rgb[1, 1, 1])
        frames[frames_count] = frame_rgb

        # Frames count.
        frames_count += 1
        
        # Plotting current frame.
        # print(f"Frame number: {frames_count}")
        # clear_output(wait=True)
        # plt.imshow(frame_rgb)
        # plt.axis('off')
        # plt.show()

        # 0.2 second pause.
        # time.sleep(0.001)
        
except KeyboardInterrupt:
    print("Process terminated by keyboard interruption")
        

















frames.shape
print(frames[50, 1000, 100, 0])



# Variable for storing intensity of each pixel.
frame_intent_values = np.zeros(frames.shape[0])


for ith_frame in range(frames.shape[0]):

    # Extracting Red, Green and Blue channel values of centroid pixel of a frame.
    red_channel = frames[ith_frame, :, :, 1]
    print(red_channel[4, 4])

    # Calculating intensity usig formula.
    # frame_intensity = 0.299 * red_channel + 0.587 * green_channel + 0.114 * blue_channel
    average_red = np.mean(red_channel)
    print(average_red)
    
    frame_intent_values[ith_frame] = average_red


# Plotting intensity values against each frame.
plt.plot(frame_intent_values, color='red', marker='.')
plt.title("Intensity of each frame.")
plt.xlabel("Frame no.")
plt.ylabel("Intensity of centroid pixel")

    


# Sampling rate of iPhone 11 is 60 frames per sec.
fps = 60
Ts = 1.0 / fps


intensity_detrended = frame_intent_values - np.mean(frame_intent_values)

# Apply a Hamming window to smooth the edges of the signal and prevent spectral leakage
win = windows.hamming(frames.shape[0])
windowed_signal = intensity_detrended * win

fft_output = np.abs(np.fft.rfft(windowed_signal))
fft_frequencies = np.fft.rfftfreq(frames.shape[0], d=Ts)

# Convert frequency vector from Hz to Beats Per Minute (BPM)
frequencies_bpm = fft_frequencies * 60.0


# Filter out anything outside the reasonable human window of 40 to 200 BPM
min_bpm, max_bpm = 40.0, 200.0
valid_indices = np.where((frequencies_bpm >= min_bpm) & (frequencies_bpm <= max_bpm))[0]

bpm_range = frequencies_bpm[valid_indices]
fft_range = fft_output[valid_indices]

max_idx = np.argmax(fft_range)
estimated_heart_rate = bpm_range[max_idx]

print(f"Estimated Heart Rate: {estimated_heart_rate:.1f} BPM")


# 6. Visualization
plt.figure(figsize=(10, 6))


# Plot FFT Spectrum
plt.subplot(2, 1, 2)
plt.plot(bpm_range, fft_range, color='royalblue', linewidth=2, label='Spectrum')
plt.axvline(x=estimated_heart_rate, color='darkorange', linestyle='--', 
            label=f'Detected Peak: {estimated_heart_rate:.1f} BPM')
plt.scatter(estimated_heart_rate, fft_range[max_idx], color='darkorange', s=50, zorder=5)

plt.title('Frequency Spectrum (Heart Rate Isolation)')
plt.xlabel('Heart Rate (Beats Per Minute)')
plt.ylabel('Magnitude (Arbitrary Units)')
plt.xlim(min_bpm, max_bpm)
plt.legend()
plt.grid(True, linestyle='--', alpha=0.6)

plt.tight_layout()
plt.show()


import numpy as np
import matplotlib.pyplot as plt
from scipy.signal import windows

# --- Setup Dummy Data for Verification (Replace this with your actual X matrix) ---
# Supposing X is an m x 2 numpy array: X[:, 0] is frame index, X[:, 1] is light intensity
# Let's assume a video length of 15 seconds at 30 FPS with a 72 BPM (1.2 Hz) pulse.
np.random.seed(42)
m = 450  # 15 seconds * 30 fps
frames = np.arange(m)
fs_assumed = 30.0  # Assumed frame rate (frames per second)

# Simulated PPG signal: DC offset + slow drift + 72 BPM heartbeat + high frequency noise
clean_pulse = np.sin(2 * np.pi * (72 / 60) * (frames / fs_assumed))
dc_offset = 2000
slow_drift = 50 * np.sin(2 * np.pi * 0.05 * (frames / fs_assumed))
noise = np.random.normal(0, 0.2, m)
simulated_intensity = dc_offset + slow_drift + clean_pulse + noise

# Constructing your matrix format
X = np.column_stack((frames, simulated_intensity))
# ---------------------------------------------------------------------------------


# 1. Extract Vectors and Determine Sampling Parameters
frame_numbers = X[:, 0]
intensity = X[:, 1]
total_samples = len(intensity)

# If your frame column contains precise millisecond timestamps instead of indices,
# you should compute Fs dynamically: Fs = 1.0 / np.mean(np.diff(timestamps_in_seconds))
Fs = 30.0  

# 2. Pre-processing: Detrend and Window
# Remove the mean to eliminate the massive 0 Hz peak caused by the phone flash
intensity_detrended = intensity - np.mean(intensity)

# Apply a Hamming window to smooth the edges of the signal and prevent spectral leakage
win = windows.hamming(total_samples)
windowed_signal = intensity_detrended * win


# 3. Compute the Fast Fourier Transform (FFT)
# Compute the real-input FFT (rfft is optimized for real signals like your intensity data)
fft_magnitudes = np.abs(np.fft.rfft(windowed_signal))
fft_frequencies = np.fft.rfftfreq(total_samples, d=1.0/Fs)

# Convert frequency vector from Hz to Beats Per Minute (BPM)
frequencies_bpm = fft_frequencies * 60.0


# 4. Isolate the Human Heart Rate Band
# Filter out anything outside the reasonable human window of 40 to 200 BPM
min_bpm, max_bpm = 40.0, 200.0
valid_indices = np.where((frequencies_bpm >= min_bpm) & (frequencies_bpm <= max_bpm))[0]

bpm_range = frequencies_bpm[valid_indices]
fft_range = fft_magnitudes[valid_indices]


# 5. Find the Heart Rate Peak
max_idx = np.argmax(fft_range)
estimated_heart_rate = bpm_range[max_idx]

print(f"Estimated Heart Rate: {estimated_heart_rate:.1f} BPM")


# 6. Visualization
plt.figure(figsize=(10, 6))

# Plot Raw Signal
plt.subplot(2, 1, 1)
plt.plot(frame_numbers, intensity, color='crimson', label='Raw Light Intensity')
plt.title('Raw Light Intensity (Finger Over Camera Flash)')
plt.xlabel('Frame Number')
plt.ylabel('Intensity Value')
plt.grid(True, linestyle='--', alpha=0.6)

# Plot FFT Spectrum
plt.subplot(2, 1, 2)
plt.plot(bpm_range, fft_range, color='royalblue', linewidth=2, label='Spectrum')
plt.axvline(x=estimated_heart_rate, color='darkorange', linestyle='--', 
            label=f'Detected Peak: {estimated_heart_rate:.1f} BPM')
plt.scatter(estimated_heart_rate, fft_range[max_idx], color='darkorange', s=50, zorder=5)

plt.title('Frequency Spectrum (Heart Rate Isolation)')
plt.xlabel('Heart Rate (Beats Per Minute)')
plt.ylabel('Magnitude (Arbitrary Units)')
plt.xlim(min_bpm, max_bpm)
plt.legend()
plt.grid(True, linestyle='--', alpha=0.6)

plt.tight_layout()
plt.show()



